---
import Base from '../layouts/Base.astro';
import { Optimizer } from '../island/Optimizer';
import icon from '../../slipstream-brand-kit/assets/logo/slipstream-icon-dark.svg?url';
import lettering from '../../slipstream-brand-kit/assets/logo/slipstream-lettering-dark.svg?url';
---

<Base title="Slipstream — glTF/GLB optimizer">
  <div class="shell">
    <header class="top">
      <div class="top-in">
        <div class="lockup">
          <img class="mark" src={icon} alt="" width="32" height="32" />
          <img class="lettering" src={lettering} alt="Slipstream" width="140" height="35" />
        </div>
        {/* Permanent — visible in every state, never scrolls out of reach. */}
        <p class="privacy-kicker" data-testid="privacy-kicker">
          100% local &middot; nothing leaves your machine
        </p>
      </div>
    </header>

    {/* The page IS the tool: the optimizer island owns the console —
        dropzone, validation, worker analysis, model report, run, result. */}
    <main class="hero">
      <div class="hero-in">
        <section class="pitch">
          <p class="kicker">In-browser&nbsp;·&nbsp;glTF&nbsp;/&nbsp;GLB optimizer</p>
          <h1 class="headline">
            Lighter models.<br />
            <span class="underlined">
              Same shape.
              {/* Hand-drawn stroke, not a rule — one pen pass. Inline SVG so
                  the path takes kit tokens (stroke="var(--ss-accent)"). */}
              <svg class="sig" viewBox="0 0 320 26" preserveAspectRatio="none" aria-hidden="true">
                <path class="sig-main" d="M5 15 C 38 7, 74 21, 122 14 C 164 8, 196 6, 234 12 C 262 16, 292 15, 315 9" />
              </svg>
            </span>
          </h1>
          <p class="lede">
            DRACO geometry compression and WebP textures, processed entirely in
            your browser. Your model never leaves your machine.
          </p>
          <p class="wire">KHR_draco_mesh_compression · EXT_texture_webp</p>
        </section>

        <Optimizer client:load />
      </div>
    </main>

    <section class="fold" id="how-it-works" data-reveal-group>
      <div class="fold-in">
        <p class="fold-k">How it works</p>
        <h2 class="fold-h">Three sectors, one worker.</h2>
        <div class="fold-cards">
          <article class="fold-card" data-reveal>
            <p class="fold-card-n">S1</p>
            <h3 class="fold-card-h">Textures</h3>
            <p class="fold-card-p">
              Every texture is decoded and re-encoded to WebP, per-role quality
              defaults with per-texture overrides where you need them.
            </p>
          </article>
          <article class="fold-card" data-reveal>
            <p class="fold-card-n">S2</p>
            <h3 class="fold-card-h">Geometry</h3>
            <p class="fold-card-p">
              Meshes are compressed with DRACO. Vertex count and shape are
              untouched — only the bytes they cost shrink.
            </p>
          </article>
          <article class="fold-card" data-reveal>
            <p class="fold-card-n">S3</p>
            <h3 class="fold-card-h">Write</h3>
            <p class="fold-card-p">
              Compressed geometry and textures are repacked into one GLB,
              ready to download straight from the tab.
            </p>
          </article>
        </div>
      </div>
    </section>

    <section class="fold" id="privacy" data-reveal-group>
      <div class="fold-in">
        <p class="fold-k">Privacy</p>
        <h2 class="fold-h">Nothing leaves your machine.</h2>
        <div class="fold-prose" data-reveal>
          <p>
            There is no upload path in this codebase. Your file goes from disk to
            an <code>ArrayBuffer</code>, into a Web Worker, and back out as a
            downloadable blob — the network tab stays empty for the whole run.
          </p>
          <p>
            This isn&rsquo;t just a claim: the end-to-end test suite asserts zero
            non-local network requests during a full optimize run, on every build.
          </p>
        </div>
      </div>
    </section>

    <section class="fold" id="credits" data-reveal-group>
      <div class="fold-in">
        <p class="fold-k">Credits</p>
        <h2 class="fold-h">Honest machinery.</h2>
        <div class="fold-prose" data-reveal>
          <p>
            Demo model: Perseverance rover, NASA/JPL-Caltech — public domain
            (CC0). Code is MIT and open source, built on gltf-transform, DRACO
            and jSquash. Optimization happens in code; nothing here is
            hand-tuned per model.
          </p>
        </div>
      </div>
    </section>

    <footer class="foot">
      <p>Free &amp; open source · MIT</p>
    </footer>
  </div>
</Base>

<script>
  // Staggered scroll-into-view reveal — progressive enhancement only. Without
  // this script every section is fully visible by default (no CSS hides
  // anything up front), so a JS failure never hides content.
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const groups = document.querySelectorAll<HTMLElement>('[data-reveal-group]');
    groups.forEach((group) => {
      const items = Array.from(group.querySelectorAll<HTMLElement>('[data-reveal]'));
      if (items.length === 0) return;
      items.forEach((el, i) => {
        el.style.opacity = '0';
        el.style.transform = 'translateY(6px)';
        el.style.transition = `opacity 0.5s ease ${i * 60}ms, transform 0.5s ease ${i * 60}ms`;
      });
      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (!entry.isIntersecting) continue;
            items.forEach((el) => {
              el.style.opacity = '1';
              el.style.transform = 'none';
            });
            observer.unobserve(entry.target);
          }
        },
        { threshold: 0.15 },
      );
      observer.observe(group);
    });
  }
</script>

<style>
  .shell {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
  }

  /* ---- Column: comfortable max below 1920, chassis floor at 2K+ ---- */
  .top-in,
  .hero-in,
  .fold-in {
    width: 100%;
    max-width: 1280px;
    margin-inline: auto;
    padding-inline: var(--ss-gutter);
  }
  @media (min-width: 1920px) {
    .top-in,
    .hero-in,
    .fold-in {
      max-width: 1880px;
    }
    /* The lockup reads at 2560 — a fixed px logo would go quiet next to the
       type scale's own growth past 1920 (typography.css clamps to 2560). */
    .mark {
      width: 40px;
      height: 40px;
    }
    .lettering {
      width: 172px;
      height: 43px;
    }
  }

  /* ---- Top bar: full-bleed hairline, permanent privacy kicker ---- */
  .top {
    border-bottom: var(--ss-hairline-w) solid var(--ss-border-strong);
  }
  .top-in {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--ss-space-4);
    padding-block: var(--ss-space-4);
  }
  .lockup {
    display: flex;
    align-items: center;
    gap: var(--ss-space-3);
  }
  .privacy-kicker {
    font-family: var(--ss-font-mono);
    font-size: var(--ss-fs-kicker);
    font-weight: var(--ss-w-semibold);
    letter-spacing: var(--ss-tracking-kicker);
    text-transform: uppercase;
    color: var(--ss-text-muted);
  }

  /* ---- Hero: the tool fills the first viewport ---- */
  .hero {
    position: relative;
    flex: 1;
    display: flex;
    background: var(--ss-wash-top);
  }
  /* Vertical hierarchy: the eye drops headline → dropzone, one axis. The
     pitch centres; the island stretches and the dropzone caps itself
     (optimizer.css) so it reads as a target, not a banner. */
  .hero-in {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--ss-space-7);
    padding-block: var(--ss-space-6);
  }

  .pitch {
    align-self: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--ss-space-4);
  }

  .kicker {
    font-family: var(--ss-font-mono);
    font-size: var(--ss-fs-kicker);
    font-weight: var(--ss-w-semibold);
    letter-spacing: var(--ss-tracking-kicker);
    text-transform: uppercase;
    color: var(--ss-text-label);
  }

  .headline {
    font-family: var(--ss-font-display);
    font-size: clamp(3rem, 1.2rem + 4vw, 6.2rem);
    font-weight: var(--ss-w-semibold);
    line-height: var(--ss-lh-tight);
    letter-spacing: var(--ss-tracking-impact);
  }

  /* The promise gets the live line: a hand-drawn amber stroke that writes
     itself in like a signature. */
  .underlined {
    position: relative;
    display: inline-block;
  }
  .sig {
    position: absolute;
    left: -0.03em;
    bottom: -0.22em;
    width: 103%;
    height: 0.26em;
    overflow: visible;
  }
  .sig path {
    fill: none;
    stroke: var(--ss-accent);
    stroke-linecap: round;
  }
  .sig-main {
    stroke-width: 5;
    stroke-dasharray: 340;
    stroke-dashoffset: 340;
    animation: sig-write 0.55s cubic-bezier(0.4, 0, 0.3, 1) 0.75s forwards;
  }
  @keyframes sig-write {
    to {
      stroke-dashoffset: 0;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .sig-main {
      animation: none;
      stroke-dashoffset: 0;
    }
  }

  .lede {
    max-width: 52ch;
    color: var(--ss-text-muted);
    line-height: var(--ss-lh-relaxed);
  }

  .wire {
    font-family: var(--ss-font-mono);
    font-size: var(--ss-fs-small);
    color: var(--ss-text-muted);
  }

  /* Dropzone / report panel styles live with the island (src/island/optimizer.css) —
     Astro's style scoping can't reach Preact-rendered DOM. */

  /* ---- Below-fold sections: V2's editorial air, generous rhythm ---- */
  .fold {
    border-top: var(--ss-hairline-w) solid var(--ss-border-strong);
  }
  .fold-in {
    padding-block: var(--ss-space-9);
  }
  .fold-k {
    display: flex;
    align-items: center;
    gap: var(--ss-space-3);
    font-family: var(--ss-font-mono);
    font-size: var(--ss-fs-kicker);
    font-weight: var(--ss-w-semibold);
    letter-spacing: var(--ss-tracking-kicker);
    text-transform: uppercase;
    color: var(--ss-text-label);
  }
  .fold-k::after {
    content: '';
    flex: 1;
    height: var(--ss-hairline-w);
    background: var(--ss-border-strong);
    min-width: var(--ss-space-6);
  }
  .fold-h {
    margin-top: var(--ss-space-4);
    font-family: var(--ss-font-display);
    font-size: clamp(2.2rem, 1.4rem + 2.6vw, 4rem);
    font-weight: var(--ss-w-semibold);
    line-height: var(--ss-lh-snug);
    letter-spacing: var(--ss-tracking-tight);
    text-wrap: balance;
    max-width: 20ch;
  }

  .fold-cards {
    margin-top: var(--ss-space-7);
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--ss-space-5);
  }
  .fold-card {
    background: var(--ss-surface);
    border: var(--ss-hairline-w) solid var(--ss-hairline);
    border-radius: var(--ss-radius-md);
    box-shadow: var(--ss-edge-lit);
    padding: var(--ss-space-5);
  }
  .fold-card-n {
    font-family: var(--ss-font-mono);
    font-size: var(--ss-fs-kicker);
    font-weight: var(--ss-w-semibold);
    letter-spacing: var(--ss-tracking-kicker);
    color: var(--ss-accent-text);
  }
  .fold-card-h {
    margin-top: var(--ss-space-2);
    font-family: var(--ss-font-display);
    font-size: var(--ss-fs-h3);
    font-weight: var(--ss-w-semibold);
  }
  .fold-card-p {
    margin-top: var(--ss-space-3);
    color: var(--ss-text-muted);
    line-height: var(--ss-lh-relaxed);
  }

  .fold-prose {
    margin-top: var(--ss-space-7);
    display: flex;
    flex-direction: column;
    gap: var(--ss-space-4);
    max-width: 68ch;
  }
  .fold-prose p {
    color: var(--ss-text-muted);
    line-height: var(--ss-lh-relaxed);
  }
  .fold-prose code {
    font-family: var(--ss-font-mono);
    font-size: 0.9em;
    color: var(--ss-text-body);
  }

  /* ---- Footer ---- */
  .foot {
    border-top: var(--ss-hairline-w) solid var(--ss-hairline);
    padding: var(--ss-space-4) var(--ss-gutter);
    font-family: var(--ss-font-mono);
    font-size: var(--ss-fs-kicker);
    letter-spacing: var(--ss-tracking-kicker);
    text-transform: uppercase;
    color: var(--ss-text-muted);
  }

  /* ---- Load-in: one orchestrated pass, killed by reduced-motion ---- */
  .top,
  .pitch > *,
  .foot {
    animation: rise 0.5s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  .pitch > :nth-child(1) { animation-delay: 60ms; }
  .pitch > :nth-child(2) { animation-delay: 120ms; }
  .pitch > :nth-child(3) { animation-delay: 180ms; }
  .pitch > :nth-child(4) { animation-delay: 240ms; }
  .foot { animation-delay: 380ms; }

  @keyframes rise {
    from {
      opacity: 0;
      translate: 0 12px;
    }
    to {
      opacity: 1;
      translate: 0 0;
    }
  }

  /* ---- Mobile ---- */
  @media (max-width: 900px) {
    .hero-in {
      gap: var(--ss-space-6);
      justify-content: flex-start;
      padding-block: var(--ss-space-6);
    }
    .fold-cards {
      grid-template-columns: 1fr;
    }
    .top-in {
      flex-wrap: wrap;
      row-gap: var(--ss-space-2);
    }
  }
</style>
